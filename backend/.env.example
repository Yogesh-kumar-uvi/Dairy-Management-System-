# Copy to .env and fill in values. NEVER commit .env
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/dairy-management

# Use long random strings (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Comma-separated whitelist of allowed frontend origins (Vercel URL in production)
CLIENT_URLS=http://localhost:3000

# SMTP for forgot/reset password emails (optional in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Dairy MS <no-reply@dairyms.local>
